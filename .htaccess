# misc-api URL Rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 禁止直接访问 config 目录
    RewriteRule ^config/ - [F,L]

    # 美观网关：/apis/{短码} → apis.php/{短码}（PATH_INFO；列表 /apis 不匹配本规则）
    RewriteRule ^apis/([a-z0-9]{3,64})/?$ apis.php/$1 [QSA,L]
</IfModule>

# 允许 /apis.php/短码 把多余路径交给 PHP（PATH_INFO）
<IfModule mod_cgi.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php7.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php8.c>
    AcceptPathInfo On
</IfModule>

# 404 错误页
ErrorDocument 404 /404.php

# 禁止目录浏览
Options -Indexes
