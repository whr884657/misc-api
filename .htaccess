# misc-api URL Rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 禁止直接访问 config 目录
    RewriteRule ^config/ - [F,L]
</IfModule>

# 允许 /apis.php/短码 把多余路径交给 PHP（PATH_INFO）
<IfModule mod_cgi.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php7.c>
    AcceptPathInfo On
</IfModule>
<IfModule mod_php8.c>
    AcceptPathInfo On
</IfModule>

# 404 错误页
ErrorDocument 404 /404.php

# 禁止目录浏览
Options -Indexes
