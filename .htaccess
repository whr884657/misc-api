# misc-api URL Rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteRule ^config/ - [F,L]

    # /apis/{slug} -> apis.php?_vs_slug= (proxy; must be before generic id rule)
    RewriteRule ^apis/([a-z0-9]+)/?$ apis.php?_vs_slug=$1 [QSA,L]

    # Generic: /{page}/{numericId} -> /{page}.php?id= (detail/article/...)
    RewriteRule ^([a-z0-9_-]+)/([0-9]+)/?$ $1.php?id=$2 [QSA,L]
</IfModule>

ErrorDocument 404 /404.php
Options -Indexes
