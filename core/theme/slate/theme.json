{
    "id": "slate",
    "name": "主题二",
    "version": "2.12.1",
    "author": "misc-api",
    "description": "主题二：API 平台风首页，搜索与分类筛选；电脑端顶栏，导航可切换抽屉或右下角 FAB 弹出",
    "preview": "preview.png",
    "settings": [
        {
            "key": "hero_title",
            "label": "首页主标题",
            "type": "text",
            "placeholder": "留空则显示「欢迎使用 {站点名称}」",
            "default": ""
        },
        {
            "key": "hero_lead",
            "label": "首页副文案",
            "type": "textarea",
            "placeholder": "留空则使用站点描述，前台以打字效果展示",
            "default": ""
        },
        {
            "key": "show_stats",
            "label": "显示首页统计区",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "nav_expand_mode",
            "label": "导航展开方式",
            "type": "select",
            "default": "top_drawer",
            "options": [
                {"value": "top_drawer", "label": "顶部三横线 · 右侧抽屉（默认）"},
                {"value": "fab_popup", "label": "右下角圆形按钮 · 向上弹出"}
            ]
        }
    ]
}
