{
    "id": "slate",
    "name": "主题二",
    "version": "2.18.0",
    "author": "misc-api",
    "description": "主题二：可配首页统计与浅色主题色；API 平台风首页与全部接口页",
    "preview": "preview.png",
    "settings": [
        {
            "key": "hero_title",
            "label": "首页主标题",
            "type": "text",
            "placeholder": "留空则显示「欢迎使用 {站点名称}」",
            "default": ""
        },
        {
            "key": "hero_lead",
            "label": "首页副文案",
            "type": "textarea",
            "placeholder": "留空则使用站点描述，前台以打字效果展示",
            "default": ""
        },
        {
            "key": "show_stats",
            "label": "显示首页统计区",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_stat_cats",
            "label": "统计：接口分类数",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_stat_apis",
            "label": "统计：接口总数",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_stat_users",
            "label": "统计：注册用户数",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_stat_today",
            "label": "统计：今日调用次数",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_stat_calls",
            "label": "统计：累计调用次数",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "color_preset",
            "label": "默认主题色（浅色）",
            "type": "select",
            "default": "green",
            "options": [
                {"value": "green", "label": "浅绿（默认）"},
                {"value": "rose", "label": "浅玫瑰"},
                {"value": "orange", "label": "浅橙"},
                {"value": "yellow", "label": "浅黄"},
                {"value": "mint", "label": "薄荷"},
                {"value": "sky", "label": "天空蓝"},
                {"value": "violet", "label": "浅紫"},
                {"value": "pink", "label": "浅粉"},
                {"value": "cyan", "label": "浅青"}
            ]
        },
        {
            "key": "nav_expand_mode",
            "label": "导航展开方式（前台 + 用户中心）",
            "type": "select",
            "default": "top_drawer",
            "options": [
                {"value": "top_drawer", "label": "顶部三横线 · 右侧抽屉（默认）"},
                {"value": "fab_popup", "label": "右下角圆形按钮 · 向上弹出"}
            ]
        },
        {
            "key": "show_runtime",
            "label": "显示网站运行时间",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_footer_qr",
            "label": "显示页脚二维码",
            "type": "checkbox",
            "default": true
        }
    ]
}
